#!/usr/bin/env bash
# ytchan - download transcripts for an entire YouTube channel
# Failed downloads get re-queued at the back with exponential backoff.
# Usage: ytchan [ytran options] <channel_url>

if [ $# -lt 1 ]; then
    echo "Usage: ytchan [ytran options] <channel_url>"
    exit 1
fi

MIN_DELAY=5
MAX_DELAY=1800
INITIAL_DELAY=10
BACKOFF_MULT=3
DECREASE=2

ARGS=("$@")
CHANNEL_URL="${ARGS[-1]}"
YTRAN_OPTS=("--no-summary" "${ARGS[@]:0:$#-1}")

DB_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/ytran"
DB="$DB_DIR/youtube-transcripts.db"

echo "Fetching video list from: $CHANNEL_URL"
mapfile -t ALL_IDS < <(yt-dlp --flat-playlist --print id "$CHANNEL_URL" 2>/dev/null)

echo "Found ${#ALL_IDS[@]} videos"

# Filter out videos already downloaded (resume-safe across restarts)
QUEUE=()
if [ -f "$DB" ]; then
    mapfile -t DONE_IDS < <(sqlite3 "$DB" \
        "SELECT video_id FROM videos WHERE raw_transcript IS NOT NULL AND raw_transcript != ''")
    declare -A DONE_MAP
    for D in "${DONE_IDS[@]}"; do DONE_MAP["$D"]=1; done
    for VID in "${ALL_IDS[@]}"; do
        [ -z "${DONE_MAP[$VID]+x}" ] && QUEUE+=("$VID")
    done
    SKIPPED=$(( ${#ALL_IDS[@]} - ${#QUEUE[@]} ))
    [ "$SKIPPED" -gt 0 ] && echo "Skipped $SKIPPED already-downloaded videos"
else
    QUEUE=("${ALL_IDS[@]}")
fi

TOTAL=${#QUEUE[@]}
echo "$TOTAL videos to process"

DONE=0
DELAY=$INITIAL_DELAY
CEILING_FAILS=0

while [ ${#QUEUE[@]} -gt 0 ]; do
    VID="${QUEUE[0]}"
    QUEUE=("${QUEUE[@]:1}")

    echo "[$DONE done, $((${#QUEUE[@]} + 1)) remaining of $TOTAL] $VID"
    ytran "${YTRAN_OPTS[@]}" "https://www.youtube.com/watch?v=$VID"

    if [ $? -eq 0 ]; then
        DONE=$((DONE + 1))
        CEILING_FAILS=0
        DELAY=$((DELAY - DECREASE))
        [ "$DELAY" -lt "$MIN_DELAY" ] && DELAY=$MIN_DELAY
    else
        QUEUE+=("$VID")
        echo "  failed — re-queued (${#QUEUE[@]} remaining)"
        DELAY=$((DELAY * BACKOFF_MULT))
        if [ "$DELAY" -ge "$MAX_DELAY" ]; then
            DELAY=$MAX_DELAY
            CEILING_FAILS=$((CEILING_FAILS + 1))
            if [ "$CEILING_FAILS" -ge 4 ]; then
                echo "Giving up: 4 failures at max backoff"
                break
            fi
        else
            CEILING_FAILS=0
        fi
    fi

    # rate limit with jitter (±20%)
    if [ ${#QUEUE[@]} -gt 0 ]; then
        JITTER=$(( (RANDOM % (DELAY * 4 / 10 + 1)) - DELAY * 2 / 10 ))
        ACTUAL=$((DELAY + JITTER))
        [ "$ACTUAL" -lt "$MIN_DELAY" ] && ACTUAL=$MIN_DELAY
        if [ -t 1 ]; then
            # interactive terminal — show countdown
            for (( LEFT=ACTUAL; LEFT>0; LEFT-- )); do
                printf "\r    waiting %ds " "$LEFT"
                sleep 1
            done
            printf "\r%*s\r" $((ACTUAL < 100 ? 19 : 20)) ""
        else
            if [ "$ACTUAL" -ge 60 ]; then
                echo "    waiting ${ACTUAL}s ($(( ACTUAL / 60 ))m$(( ACTUAL % 60 ))s)..."
            else
                echo "    waiting ${ACTUAL}s..."
            fi
            sleep "$ACTUAL"
        fi
    fi
done

GAVE_UP=${#QUEUE[@]}
echo "Done: $DONE downloaded, $GAVE_UP gave up"
