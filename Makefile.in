PREFIX = @PREFIX@
PYTHON = @PYTHON@
BINDIR = $(PREFIX)/bin
MANDIR = $(PREFIX)/share/man/man1

.PHONY: all install uninstall clean distclean check dist

all:
	@echo "Nothing to build. Run 'make install' to install."

install:
	install -d $(DESTDIR)$(BINDIR)
	install -m 755 ytran $(DESTDIR)$(BINDIR)/ytran
	install -d $(DESTDIR)$(MANDIR)
	install -m 644 ytran.1 $(DESTDIR)$(MANDIR)/ytran.1

uninstall:
	rm -f $(DESTDIR)$(BINDIR)/ytran
	rm -f $(DESTDIR)$(MANDIR)/ytran.1

clean:

distclean: clean
	rm -f Makefile

check:
	$(PYTHON) -c "import anthropic" 2>/dev/null || echo "Warning: anthropic package not installed"
	@echo "Checks passed."

dist:
	mkdir -p ytran-1.0
	cp ytran configure Makefile.in requirements.txt ytran-1.0/
	cp README.md COPYING AUTHORS NEWS ChangeLog INSTALL ytran.1 ytran-1.0/
	tar czf ytran-1.0.tar.gz ytran-1.0
	rm -rf ytran-1.0
	@echo "Created ytran-1.0.tar.gz"
