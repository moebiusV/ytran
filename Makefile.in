PREFIX = @PREFIX@
CC = @CC@
CFLAGS = -std=c17 -Wall -Wextra -O2
LDLIBS = -Wl,-Bstatic -lsqlite3 -Wl,-Bdynamic -lcurl -lpthread -ldl -lm
BINDIR = $(PREFIX)/bin
MANDIR = $(PREFIX)/share/man/man1

.PHONY: all install uninstall clean distclean check dist

all: c/ytran

c/ytran: c/ytran.c c/deps/cjson/cJSON.c
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ c/ytran.c c/deps/cjson/cJSON.c $(LDLIBS)

install: c/ytran
	install -d $(DESTDIR)$(BINDIR)
	install -m 755 c/ytran $(DESTDIR)$(BINDIR)/ytran
	install -d $(DESTDIR)$(MANDIR)
	install -m 644 ytran.1 $(DESTDIR)$(MANDIR)/ytran.1

uninstall:
	rm -f $(DESTDIR)$(BINDIR)/ytran
	rm -f $(DESTDIR)$(MANDIR)/ytran.1

clean:
	rm -f c/ytran

distclean: clean
	rm -f Makefile

check: c/ytran
	@echo "Build OK."

dist:
	mkdir -p ytran-1.0
	cp configure Makefile.in requirements.txt ytran.py ytran-1.0/
	cp -r c ytran-1.0/
	cp README.md COPYING AUTHORS NEWS ChangeLog INSTALL ytran.1 ytran-1.0/
	tar czf ytran-1.0.tar.gz ytran-1.0
	rm -rf ytran-1.0
	@echo "Created ytran-1.0.tar.gz"
