#!/bin/sh
# configure script for ytran

PREFIX=/usr/local
CC=${CC:-cc}

for arg in "$@"; do
    case "$arg" in
        --prefix=*) PREFIX="${arg#--prefix=}" ;;
        --help)
            echo "Usage: ./configure [OPTIONS]"
            echo ""
            echo "  --prefix=DIR   Installation prefix [/usr/local]"
            echo ""
            exit 0
            ;;
        *) echo "Unknown option: $arg"; exit 1 ;;
    esac
done

# Check C compiler
if ! command -v "$CC" >/dev/null 2>&1; then
    echo "Error: C compiler '$CC' not found"
    exit 1
fi

# Check required libraries
MISSING=""
for lib in libcurl sqlite3; do
    if ! pkg-config --exists "$lib" 2>/dev/null; then
        MISSING="$MISSING $lib"
    fi
done

if [ -n "$MISSING" ]; then
    echo "Missing libraries:$MISSING"
    echo ""
    echo "Install with:"
    echo "  sudo apt-get install libcurl4-openssl-dev libsqlite3-dev"
    exit 1
fi

echo "CC:      $CC"
echo "Prefix:  $PREFIX"

sed -e "s|@PREFIX@|$PREFIX|g" \
    -e "s|@CC@|$CC|g" \
    Makefile.in > Makefile

echo ""
echo "Configuration complete. Run 'make' to build."
